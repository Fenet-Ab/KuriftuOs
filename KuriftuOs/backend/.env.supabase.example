# Option A (preferred when your network supports IPv6):
# DATABASE_URL=postgresql+asyncpg://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
#
# Option B (works better on IPv4-only networks): Supabase pooler
# Replace <POOLER_USER> with "postgres.<PROJECT_REF>" from Supabase connection details.
DATABASE_URL=postgresql+psycopg://<POOLER_USER>:<PASSWORD>@aws-1-<REGION>.pooler.supabase.com:6543/postgres
SECRET_KEY=supersecretkey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
