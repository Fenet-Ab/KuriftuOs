# ── App ──────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES
REFRESH_TOKEN_EXPIRE_DAYS

# ── Database ─────────────────────────────────────────
DATABASE_URL

# ── Redis ────────────────────────────────────────────
REDIS_URL

# ── Google AI (Gemini) ───────────────────────────────
